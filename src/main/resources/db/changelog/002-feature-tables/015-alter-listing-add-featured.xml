<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Adds the `featured` flag to the listing table.
        Featured listings receive boosted visibility on the marketplace browse page.
        Defaults to FALSE so existing rows are unaffected.
    -->
    <changeSet id="015-alter-listing-add-featured" author="nour">
        <sql splitStatements="true" stripComments="true">
            ALTER TABLE listing
                ADD COLUMN IF NOT EXISTS featured BOOLEAN NOT NULL DEFAULT FALSE;

            COMMENT ON COLUMN listing.featured IS 'True when this listing has been boosted for marketplace visibility';
        </sql>
    </changeSet>
</databaseChangeLog>

