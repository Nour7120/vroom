<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="001-constraint-user-profile-unique" author="nour">
        <sql splitStatements="true" stripComments="true">
            ALTER TABLE user_profile
                ADD CONSTRAINT chk_user_profile_status
                    CHECK (status IN ('PENDING_MAIL_VERIFICATION', 'ACTIVE', 'SUSPENDED', 'BLOCKED'));
        </sql>
    </changeSet>
</databaseChangeLog>