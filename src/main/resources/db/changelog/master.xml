<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Migration execution order:
          1. baseline-tables  – core domain tables shared across the application (users, auth, attachments, audit)
          2. feature-tables   – feature-specific tables (garage, marketplace)
          3. constraints      – UNIQUE + FOREIGN KEY + CHECK constraints across all tables
          4. indexes          – all CREATE INDEX statements
          5. (reserved)       – future data/seed changesets
    -->

    <includeAll path="db/changelog/001-baseline-tables" relativeToChangelogFile="false"/>
    <includeAll path="db/changelog/002-feature-tables"  relativeToChangelogFile="false"/>
    <includeAll path="db/changelog/003-constraints"     relativeToChangelogFile="false"/>
    <includeAll path="db/changelog/004-indexes"         relativeToChangelogFile="false"/>

</databaseChangeLog>
