<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Adds last_password_reset_email_sent_at to user_profile.
        Used by the registration module to enforce forgot-password resend throttling:
          - minimum interval between consecutive password-reset email requests
          - daily maximum retry cap (tracked in-process via ConcurrentHashMap)
    -->
    <changeSet id="011-alter-user-profile-add-last-password-reset-email-sent-at" author="nour">
        <sql splitStatements="true" stripComments="true">
            ALTER TABLE user_profile
                ADD COLUMN IF NOT EXISTS last_password_reset_email_sent_at TIMESTAMPTZ;

            COMMENT ON COLUMN user_profile.last_password_reset_email_sent_at
                IS 'Timestamp of the last Keycloak password-reset email dispatch; used to enforce forgot-password resend cooldown';
        </sql>
    </changeSet>

</databaseChangeLog>

